    "# -------------------------------\n",
    "# 1. Load Industrial Dataset\n",
    "# -------------------------------\n",
    "# Simulated industrial data for predictive maintenance\n",
    "np.random.seed(42)\n",
    "data = pd.DataFrame({\n",
    "    'temperature': np.random.uniform(20, 100, 1000),\n",
    "    'pressure': np.random.uniform(1, 10, 1000),\n",
    "    'vibration': np.random.uniform(0.1, 5.0, 1000),\n",
    "    'machine_age': np.random.randint(1, 10, 1000),\n",
    "    'failure': np.random.choice([0, 1], size=1000)\n",
    "})\n",
    "\n",
    "# Normalize the data\n",
    "scaler = MinMaxScaler()\n",
    "data_scaled = pd.DataFrame(scaler.fit_transform(data), columns=data.columns)\n",
    "data_scaled.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "31627954-1ece-4065-b84b-21aa1681b7c5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# -------------------------------\n",
    "# 2. CTGAN Training\n",
    "# -------------------------------\n",
    "ctgan = CTGAN(epochs=50)\n",
    "ctgan.fit(data_scaled, discrete_columns=['failure'])\n",
    "synthetic_ctgan = ctgan.sample(500)"
   ]
