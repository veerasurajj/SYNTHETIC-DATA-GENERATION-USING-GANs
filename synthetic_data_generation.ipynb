lass="mtk1">z</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk10">class</span><span class="mtk1">&nbsp;</span><span class="mtk16">Discriminator</span><span class="mtk1">(</span><span class="mtk16">nn</span><span class="mtk1">.</span><span class="mtk16">Module</span><span class="mtk1">)</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk10">def</span><span class="mtk1">&nbsp;</span><span class="mtk17">__init__</span><span class="mtk1">(</span><span class="mtk4">self</span><span class="mtk1">,&nbsp;</span><span class="mtk4">input_dim</span><span class="mtk1">)</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;super</span><span class="mtk14">(</span><span class="mtk1">Discriminator</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk4">self</span><span class="mtk14">)</span><span class="mtk1">.</span><span class="mtk17">__init__</span><span class="mtk14">()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk4">self</span><span class="mtk1">.model&nbsp;=&nbsp;nn.Sequential</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nn.Linear</span><span class="mtk14">(</span><span class="mtk1">input_dim</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">256</span><span class="mtk14">),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nn.ReLU</span><span class="mtk14">(),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nn.Linear</span><span class="mtk14">(</span><span class="mtk6">256</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">128</span><span class="mtk14">),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nn.ReLU</span><span class="mtk14">(),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nn.Linear</span><span class="mtk14">(</span><span class="mtk6">128</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">1</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk10">def</span><span class="mtk1">&nbsp;</span><span class="mtk17">forward</span><span class="mtk1">(</span><span class="mtk4">self</span><span class="mtk1">,&nbsp;</span><span class="mtk4">x</span><span class="mtk1">)</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;</span><span class="mtk4">self</span><span class="mtk1">.model</span><span class="mtk14">(</span><span class="mtk1">x</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Initialize&nbsp;models</span></span><br><span><span class="mtk1">generator&nbsp;=&nbsp;Generator</span><span class="mtk14">(</span><span class="mtk1">input_dim=</span><span class="mtk6">10</span><span class="mtk14">,</span><span class="mtk1">&nbsp;output_dim=data_scaled.shape</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">])</span></span><br><span><span class="mtk1">discriminator&nbsp;=&nbsp;Discriminator</span><span class="mtk14">(</span><span class="mtk1">input_dim=data_scaled.shape</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">])</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Optimizers&nbsp;and&nbsp;hyperparameters</span></span><br><span><span class="mtk1">optimizer_G&nbsp;=&nbsp;optim.RMSprop</span><span class="mtk14">(</span><span class="mtk1">generator.parameters</span><span class="mtk14">(),</span><span class="mtk1">&nbsp;lr=</span><span class="mtk6">0.00005</span><span class="mtk14">)</span></span><br><span><span class="mtk1">optimizer_D&nbsp;=&nbsp;optim.RMSprop</span><span class="mtk14">(</span><span class="mtk1">discriminator.parameters</span><span class="mtk14">(),</span><span class="mtk1">&nbsp;lr=</span><span class="mtk6">0.00005</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Data&nbsp;loader</span></span><br><span><span class="mtk1">real_data&nbsp;=&nbsp;IndustrialDataset</span><span class="mtk14">(</span><span class="mtk1">data_scaled</span><span class="mtk14">)</span></span><br><span><span class="mtk1">loader&nbsp;=&nbsp;DataLoader</span><span class="mtk14">(</span><span class="mtk1">real_data</span><span class="mtk14">,</span><span class="mtk1">&nbsp;batch_size=</span><span class="mtk6">64</span><span class="mtk14">,</span><span class="mtk1">&nbsp;shuffle=</span><span class="mtk9">True</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Training&nbsp;loop</span></span><br><span><span class="mtk20">for</span><span class="mtk1">&nbsp;epoch&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;</span><span class="mtk17">range</span><span class="mtk14">(</span><span class="mtk6">50</span><span class="mtk14">):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;i</span><span class="mtk14">,</span><span class="mtk1">&nbsp;real_samples&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;</span><span class="mtk17">enumerate</span><span class="mtk14">(</span><span class="mtk1">loader</span><span class="mtk14">):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;Train&nbsp;Discriminator</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;optimizer_D.zero_grad</span><span class="mtk14">()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z&nbsp;=&nbsp;torch.randn</span><span class="mtk14">(</span><span class="mtk1">real_samples.size</span><span class="mtk14">(</span><span class="mtk6">0</span><span class="mtk14">),</span><span class="mtk1">&nbsp;</span><span class="mtk6">10</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;fake_samples&nbsp;=&nbsp;generator</span><span class="mtk14">(</span><span class="mtk1">z</span><span class="mtk14">)</span><span class="mtk1">.detach</span><span class="mtk14">()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;loss_D&nbsp;=&nbsp;-</span><span class="mtk14">(</span><span class="mtk1">torch.mean</span><span class="mtk14">(</span><span class="mtk1">discriminator</span><span class="mtk14">(</span><span class="mtk1">real_samples</span><span class="mtk14">))</span><span class="mtk1">&nbsp;-&nbsp;torch.mean</span><span class="mtk14">(</span><span class="mtk1">discriminator</span><span class="mtk14">(</span><span class="mtk1">fake_samples</span><span class="mtk14">)))</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;loss_D.backward</span><span class="mtk14">()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;optimizer_D.step</span><span class="mtk14">()</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;p&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;discriminator.parameters</span><span class="mtk14">():</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;p.data.clamp_</span><span class="mtk14">(</span><span class="mtk6">-0.01</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">0.01</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;Train&nbsp;Generator</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;optimizer_G.zero_grad</span><span class="mtk14">()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z&nbsp;=&nbsp;torch.randn</span><span class="mtk14">(</span><span class="mtk1">real_samples.size</span><span class="mtk14">(</span><span class="mtk6">0</span><span class="mtk14">),</span><span class="mtk1">&nbsp;</span><span class="mtk6">10</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;fake_samples&nbsp;=&nbsp;generator</span><span class="mtk14">(</span><span class="mtk1">z</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;loss_G&nbsp;=&nbsp;-torch.mean</span><span class="mtk14">(</span><span class="mtk1">discriminator</span><span class="mtk14">(</span><span class="mtk1">fake_samples</span><span class="mtk14">))</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;loss_G.backward</span><span class="mtk14">()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;optimizer_G.step</span><span class="mtk14">()</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"Epoch&nbsp;</span><span class="mtk14">{</span><span class="mtk1">epoch+</span><span class="mtk6">1</span><span class="mtk14">}</span><span class="mtk5">,&nbsp;Loss&nbsp;D:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">loss_D.item</span><span class="mtk14">()}</span><span class="mtk5">,&nbsp;Loss&nbsp;G:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">loss_G.item</span><span class="mtk14">()}</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$123906188$-->Start coding or <span tabindex="0" role="button" class="link">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area" bis_skin_checked="1"></div></colab-form></div>
